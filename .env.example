# =============================================================================
# Ares Booking Platform — Environment Variables
# Copy this file to .env.local and fill in all required values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase / PostgreSQL)
# Get these from your Supabase project → Settings → Database → Connection string
# Use the "connection pooling" URL for DATABASE_URL and the direct URL for migrations.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth.js
# NEXTAUTH_URL must be the canonical URL of your app (no trailing slash).
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate.
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# -----------------------------------------------------------------------------
# Email (Magic-link login via NextAuth EmailProvider)
# Uses nodemailer under the hood. Gmail example below — use an App Password,
# NOT your regular Gmail password.
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="Ares Booking <noreply@yourdomain.com>"

# -----------------------------------------------------------------------------
# Stripe
# Get keys from https://dashboard.stripe.com/apikeys
# Use TEST keys for development; LIVE keys for production only.
# NEXT_PUBLIC_ prefix makes STRIPE_PUBLISHABLE_KEY available in the browser.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret — from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# In production: from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# OpenAI (AI chat assistant)
# Get from https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."

# -----------------------------------------------------------------------------
# Resend (Transactional email — OPTIONAL)
# If set, booking lifecycle emails are sent via Resend.
# If absent, the app falls back to console.warn and logs to NotificationLog.
# Get from https://resend.com/api-keys
# -----------------------------------------------------------------------------
# RESEND_API_KEY="re_..."
