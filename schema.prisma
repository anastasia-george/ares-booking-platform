// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// 1. Users & Auth
// -----------------------------------------------------------------------------

enum UserRole {
  CUSTOMER
  BUSINESS_OWNER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  phone     String?  // vital for SMS notifications
  role      UserRole @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe (for card-on-file on free model calls)
  stripeCustomerId String?

  // Auth Fields (NextAuth)
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Relations
  businesses       Business[]        // If they own businesses
  bookings         Booking[]         // If they are a customer
  reviews          Review[]
  reputation       ReputationScore?
  reportedDisputes Dispute[]         @relation("DisputeReporter")
}

// NextAuth Models (Mandatory for EmailProvider)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// 2. Business & Services
// -----------------------------------------------------------------------------

model Business {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  description String?
  slug        String   @unique // for friendly URLs
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Marketplace discovery fields
  suburb              String?  // e.g. "Surry Hills"
  city                String?  // e.g. "Sydney"
  state               String?  // e.g. "NSW"
  bio                 String?  @db.Text
  instagramHandle     String?
  isAcceptingModels   Boolean  @default(true)
  avgRating           Float?   // denormalised for fast listing queries

  owner                 User                   @relation(fields: [ownerId], references: [id])
  services              Service[]
  slots                 Availability[]
  bookings              Booking[]
  availabilityOverrides AvailabilityOverride[]
  policy                BusinessPolicy?
}

model Service {
  id          String  @id @default(uuid())
  businessId  String
  name        String
  description String?
  price       Int     // Model-call price in cents (0 = free)
  originalPrice Int?  // Full retail price in cents for strikethrough display
  category    String? // e.g. "Lashes", "Nails", "Facials", "Hair"
  durationMin Int     // e.g., 60
  bufferMin   Int     @default(15) // Time after service to clean up
  isActive    Boolean @default(true)

  business Business  @relation(fields: [businessId], references: [id])
  bookings Booking[]
}

// -----------------------------------------------------------------------------
// 3. Availability (The Logic)
// -----------------------------------------------------------------------------

model Availability {
  id         String @id @default(uuid())
  businessId String
  dayOfWeek  Int    // 0=Sun, 1=Mon, etc.
  startTime  String // "09:00"
  endTime    String // "17:00"

  business Business @relation(fields: [businessId], references: [id])
}

model AvailabilityOverride {
  id         String  @id @default(uuid())
  businessId String
  date       String  // "YYYY-MM-DD"
  isClosed   Boolean
  startTime  String?
  endTime    String?

  business Business @relation(fields: [businessId], references: [id])
}

// -----------------------------------------------------------------------------
// 4. Bookings (The Core)
// -----------------------------------------------------------------------------

enum BookingStatus {
  PENDING_PAYMENT    // Booking created, awaiting Stripe payment auth
  PENDING            // Payment authorised, awaiting business confirmation (MANUAL mode)
  CONFIRMED          // Business confirmed (or AUTO_CONFIRM)
  CANCELLED_BY_USER
  CANCELLED_BY_BUSINESS
  COMPLETED          // Service delivered; payment captured
  NO_SHOW            // Customer did not appear; no-show fee charged
  DISPUTED           // Under admin review
  REFUNDED           // Booking cancelled and payment refunded
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  businessId String
  serviceId  String

  startTime DateTime      // stored in UTC
  endTime   DateTime      // stored in UTC
  status    BookingStatus @default(PENDING_PAYMENT)

  // Payment info
  paymentId       String? // Stripe PaymentIntent ID (paid slots) or SetupIntent ID (free slots)
  paymentMethodId String? // Stripe PaymentMethod ID stored for free-slot no-show charges
  paymentStatus   String? // "authorized" | "paid" | "refunded" | "charged_no_show" | "failed" | "card_saved"
  depositAmount   Int?    // Deposit held in cents (may differ from full price; 0 for free slots)
  price           Int     // Snapshot of full service price at booking time (cents; 0 = free)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  business Business @relation(fields: [businessId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  review   Review?
  dispute  Dispute?
}

// -----------------------------------------------------------------------------
// 5. Business Policy (Persisted Per Business)
// -----------------------------------------------------------------------------

model BusinessPolicy {
  id                        String  @id @default(uuid())
  businessId                String  @unique
  cancellationWindowHours   Int     @default(24)  // Hours before appt: free cancel
  lateCancellationRefundPct Int     @default(0)   // % refund on late cancel
  noShowFeePercent          Int     @default(100) // % of deposit charged on no-show
  approvalMode              String  @default("AUTO_CONFIRM") // "AUTO_CONFIRM" | "MANUAL"
  minLeadTimeHours          Int     @default(2)   // Min hours before booking start
  maxLeadTimeDays           Int     @default(60)  // Max days in advance
  depositRequired           Boolean @default(true)
  depositPercent            Int     @default(50)  // % of price charged as deposit

  business Business @relation(fields: [businessId], references: [id])
}

// -----------------------------------------------------------------------------
// 6. Trust, Reputation & Disputes
// -----------------------------------------------------------------------------

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FOR_CUSTOMER
  RESOLVED_FOR_BUSINESS
  CLOSED
}

model Dispute {
  id         String        @id @default(uuid())
  bookingId  String        @unique
  reporterId String
  reason     String
  status     DisputeStatus @default(OPEN)
  resolution String?
  resolvedBy String?       // Admin userId
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id])
  reporter User    @relation("DisputeReporter", fields: [reporterId], references: [id])
}

// Reputation score per customer user (0–100).
// Decremented on no-show/late-cancel; incremented on completed bookings.
model ReputationScore {
  id          String   @id @default(uuid())
  userId      String   @unique
  score       Float    @default(100.0) // 0–100; below 50 = restricted
  noShowCount Int      @default(0)
  lateCancelCount Int  @default(0)
  completedCount  Int  @default(0)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  userId    String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g. "BOOKING_CREATED", "STATUS_CHANGE", "PAYMENT_CAPTURED"
  entityId  String   // ID of the affected booking/user/business
  actorId   String?  // userId or "SYSTEM"
  details   Json?    // Snapshot of state change
  createdAt DateTime @default(now())
}

// Log every notification attempt for observability and retry tracking.
model NotificationLog {
  id        String   @id @default(uuid())
  userId    String?
  bookingId String?
  type      String   // "BOOKING_CONFIRMATION" | "CANCELLATION" | "REMINDER" | "NO_SHOW" | "DISPUTE"
  channel   String   // "email" | "sms"
  to        String   // recipient address
  status    String   // "sent" | "failed"
  error     String?
  createdAt DateTime @default(now())
}
